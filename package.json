{
  "name": "mouse-colony-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3333",
    "build": "next build",
    "start": "next start -p 3333",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev --env-file .env.local",
    "db:migrate:prod": "prisma migrate deploy --env-file .env.local",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio --env-file .env.local",
    "db:generate": "prisma generate --env-file .env.local",
    "db:push": "prisma db push --env-file .env.local"
  },
  "prisma": {
    "seed": "node --env-file .env.local --import tsx/esm prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "next": "14.2.5",
    "next-auth": "^5.0.0-beta.25",
    "react": "^18",
    "react-dom": "^18",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
