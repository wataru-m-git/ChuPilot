# Auth.js v5
AUTH_URL=http://localhost:3333
# openssl rand -base64 32 で生成してください
AUTH_SECRET=

# データベース（CWD=プロジェクトルート からの相対パス）
DATABASE_URL="file:./data/mouse_colony.db"

# 初期管理者アカウント設定
# シードスクリプト実行時に使用されます
ADMIN_EMAIL=admin@local.lab
# 指定しない場合は「ChangeMe@123456」が使用されます
ADMIN_DEFAULT_PASSWORD=

# ユーザー登録制御（初回セットアップ後は false に設定）
ALLOW_SELF_REGISTRATION=false
